# Docker ignore file for optimized builds

# Node modules - will be installed in container
node_modules/
npm-debug.log*
yarn-error.log*

# Next.js
.next/
out/
dist/
build/

# Git
.git
.gitignore
.gitattributes

# Environment files (won't be needed if using docker env)
.env.local
.env.*.local

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Testing
coverage/
.nyc_output/

# Temporary files
tmp/
temp/
*.tmp

# Documentation
docs/
README.md

# CI/CD
.github/
.gitlab-ci.yml
.circleci/

# Docker
Dockerfile
docker-compose.yml
docker-compose.prod.yml
.dockerignore

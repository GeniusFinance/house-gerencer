# Copy and rename this file to .env.local
# Fill in your actual database credentials

# PostgreSQL Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=debt_tracker
DB_LOGGING=false

# Node Environment
NODE_ENV=development

# Google Sheets (existing configuration)
GOOGLE_SHEETS_PRIVATE_KEY_ID=your_private_key_id
GOOGLE_SHEETS_PRIVATE_KEY=your_private_key
GOOGLE_SHEETS_CLIENT_EMAIL=your_client_email
GOOGLE_SHEETS_CLIENT_ID=your_client_id
GOOGLE_SHEETS_SPREADSHEET_EXPENSE_ID=your_expense_spreadsheet_id
GOOGLE_SHEETS_SPREADSHEET_CREDIT_ID=your_credit_spreadsheet_id
GOOGLE_SHEETS_SPREADSHEET_INCOME_ID=your_income_spreadsheet_id
GOOGLE_SHEETS_EXPENSE_RANGE=Sheet1!A1:Z1000
GOOGLE_SHEETS_CREDIT_RANGE=Sheet1!A1:Z1000
GOOGLE_SHEETS_INCOME_RANGE=Sheet1!A1:Z1000
GOOGLE_SHEETS_TRANSFERS_RANGE=Transfers!A1:Z1000
